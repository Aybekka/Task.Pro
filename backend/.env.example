# Copy this file to .env and fill in the values before starting the backend.
# cp .env.example .env

PORT=3001
MONGODB_URI=mongodb://localhost:27017/taskpro
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Cloudinary — avatar görselleri buraya yükleniyor, MongoDB'de sadece secure_url tutuluyor
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Brevo HTTP API — "Need help" formundan gelen istekler buradan gönderiliyor.
# SMTP yerine HTTPS API kullanıyoruz çünkü Render gibi platformlar SMTP portlarını (587/465) engelliyor.
BREVO_API_KEY=
MAIL_FROM=
HELP_RECIPIENT_EMAIL=
