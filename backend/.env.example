# Copy this file to .env and fill in the values before starting the backend.
# cp .env.example .env

PORT=3001
MONGODB_URI=mongodb://localhost:27017/taskpro
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# Cloudinary — avatar görselleri buraya yükleniyor, MongoDB'de sadece secure_url tutuluyor
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP — "Need help" formundan gelen istekler buradan gönderiliyor (örn. Gmail app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=
HELP_RECIPIENT_EMAIL=
